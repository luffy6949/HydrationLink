PORT=4000

# IMPORTANT: must be a replica set (even a single local node) -- the
# widget-tap throttle uses a Mongo transaction, which standalone Mongo
# does not support. See README.md "MongoDB setup" section.
MONGO_URI=mongodb://localhost:27017/hydrationlink?replicaSet=rs0

THROTTLE_MINUTES=20
SNOOZE_MINUTES=30

# Provide ONE of the following for Firebase Cloud Messaging (push to
# backgrounded/killed devices). Get this from Firebase Console ->
# Project Settings -> Service Accounts -> Generate new private key.
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

NODE_ENV=development
