{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node", // ✅ FIXED: 'node10' ko badal kar stable 'node' kiya (No deprecation errors!)
    "declaration": false,
    "sourceMap": true
  },
  "include": ["src/**/*.ts"]
}